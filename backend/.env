# Copy this file from .env.example and fill the values below.
# This file is required for backend environment configuration.

SECRET_KEY=django-insecure-please-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Keycloak settings
KEYCLOAK_SERVER_URL=http://localhost:8081
KEYCLOAK_REALM=iso9001-realm
KEYCLOAK_CLIENT_ID=iso9001-client
KEYCLOAK_CLIENT_SECRET=d3XqSEHRtQHKXIEHC0GztCzgXojUOF9O
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=

# Email / SMTP settings (Mailtrap example)
EMAIL_BACKEND=anymail.backends.mailtrap.EmailBackend
MAILTRAP_API_TOKEN=bc4d7c05dfe6086c4c761d38ed4a16df
DEFAULT_FROM_EMAIL=hello@demomailtrap.co

